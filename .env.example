# Audius Developer App — https://api.audius.co/plans
# API key is required (enables PKCE OAuth write scope + uploads).
VITE_AUDIUS_API_KEY=your_api_key_here
# Optional: app bearer token if your integration still needs BearerAuth on the SDK.
# OAuth user sessions use the SDK token store; uploads after sign-in use the user access token.
VITE_AUDIUS_BEARER_TOKEN=
# Optional: override OAuth redirect (must match a URL allowed in your Audius app settings).
# Default in the browser is ${origin}/ (e.g. http://localhost:3000/)
VITE_AUDIUS_REDIRECT_URI=
# Optional: SDK "development" only for a local Audius protocol (docker audius-api, etc.).
# Default is always production (https://api.audius.co), including when you run Vite locally.
# VITE_AUDIUS_ENV=development

# Curator (artist) Audius user ID — only this user can access the dashboard from the main site. Optional if you use curator subdomain only.
VITE_ARTIST_USER_ID=your_curator_audius_user_id

# Curator subdomain (no login): when users open https://curator.yourdomain.com they get the dashboard with no sign-in. Set both to the same secret.
VITE_CURATOR_SUBDOMAIN=curator
VITE_CURATOR_KEY=your_shared_secret_here
CURATOR_KEY=your_shared_secret_here

# Supabase (backend DB) — from Supabase project Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Server (local dev)
PORT=3001
