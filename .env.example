# Audius Developer App credentials
# Get these from https://api.audius.co/plans
VITE_AUDIUS_API_KEY=your_api_key_here
VITE_AUDIUS_BEARER_TOKEN=your_bearer_token_here

# Curator (artist) Audius user ID — only this user can access the dashboard from the main site. Optional if you use curator subdomain only.
VITE_ARTIST_USER_ID=your_curator_audius_user_id

# Curator subdomain (no login): when users open https://curator.yourdomain.com they get the dashboard with no sign-in. Set both to the same secret.
VITE_CURATOR_SUBDOMAIN=curator
VITE_CURATOR_KEY=your_shared_secret_here
CURATOR_KEY=your_shared_secret_here

# Supabase (backend DB) — from Supabase project Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Server (local dev)
PORT=3001
