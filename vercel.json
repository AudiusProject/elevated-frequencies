{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": null,
  "rewrites": [
    { "source": "/api", "destination": "/api/backend" },
    { "source": "/api/(.*)", "destination": "/api/backend?__path=$1" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
